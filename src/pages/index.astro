---
import Layout from '../layouts/Layout.astro';
import { SITE, SERVICES, ZONES, TESTIMONIALS, PROJECTS } from '../data/site';

const faqs = [
  {
    q: '¿Cuánto puede costar reformar un piso de 100 m²?',
    a: 'Una reforma integral de un piso de 100 m² en el Corredor del Henares oscila entre 30.000€ y 55.000€ con materiales de calidad media-alta. El precio varía según el estado de las instalaciones, los materiales elegidos y si hay redistribución de espacios. En Trazzo360 damos precio cerrado desde el primer presupuesto: lo que firmas es lo que pagas.',
  },
  {
    q: '¿Qué puedo reformar con 20.000€?',
    a: 'Con 20.000€ puedes hacer una reforma parcial de piso: renovación completa de baño y cocina, suelos nuevos y pintura en una vivienda de 60–70 m². También alcanza para una reforma integral de baño y cocina de calidad media-alta, o para reformar íntegramente un piso pequeño de 40–50 m². Te asesoramos sin compromiso para sacar el máximo partido a tu presupuesto.',
  },
  {
    q: '¿Qué es lo más caro en una reforma?',
    a: 'Las partidas más costosas son las instalaciones (fontanería y electricidad completas representan el 25–35% del presupuesto total), seguidas de los revestimientos (alicatados, pavimentos y carpintería). En una reforma integral, renovar las instalaciones ocultas es lo que más encarece porque requiere abrir paredes y suelos. Por eso es importante hacerlo bien desde el principio.',
  },
  {
    q: '¿Qué se puede reformar con 40.000€?',
    a: 'Con 40.000€ puedes afrontar una reforma integral completa de un piso de 80–90 m² con materiales de calidad media-alta: derribo de tabiques, instalaciones nuevas, baño, cocina, suelos, pintura y carpintería. También alcanza para una reforma de lujo en un piso de 50–60 m². En Trazzo360 te presentamos varias opciones dentro de tu presupuesto con precio cerrado garantizado.',
  },
  {
    q: '¿Cuánto tarda una reforma integral en el Corredor del Henares?',
    a: 'Entre 8 y 14 semanas para un piso de 70–90 m². Fijamos la fecha de entrega en el contrato y la cumplimos. Si hay retrasos por causas propias, compensamos económicamente.',
  },
  {
    q: '¿Trabajáis en toda la zona del Corredor del Henares?',
    a: 'Sí. Cubrimos Alcalá de Henares, Torrejón de Ardoz, Coslada, San Fernando de Henares, Guadalajara, Azuqueca de Henares, Meco, Camarma de Esteruelas y municipios adyacentes. Profesionales de confianza en toda la zona, sin desplazamientos adicionales.',
  },
];

const primaryZoneDescs: Record<string, string> = {
  'alcala-de-henares': 'Nuestra zona de mayor actividad. Trabajamos en toda la ciudad: El Val, El Ensanche, Nueva Alcalá y el centro histórico. Reformas integrales de pisos de los setenta y ochenta que necesitan instalaciones completamente nuevas, así como chalets y adosados en las urbanizaciones del extrarradio que buscan redistribución y acabados de calidad.',
  'torrejon-de-ardoz': 'La segunda ciudad donde más obras ejecutamos. El parque de vivienda de Torrejón concentra muchos pisos de los ochenta con instalaciones envejecidas que requieren reforma integral. Reformas de cocinas, baños y rehabilitación completa de viviendas son los trabajos más frecuentes. Cubrimos toda la ciudad y municipios adyacentes sin coste de desplazamiento.',
  'coslada': 'Reformas de pisos medianos donde cocinas y baños concentran la mayor parte del trabajo. Muchas viviendas de Coslada tienen un potencial de redistribución que aprovechamos sin ampliar el presupuesto. Visita gratuita con respuesta en menos de 24 horas en toda la ciudad.',
  'san-fernando-de-henares': 'Reformas integrales de vivienda y trabajos en comunidades de vecinos: portales, escaleras y fachadas. San Fernando tiene un parque residencial de los años ochenta y noventa en buen estado estructural pero con instalaciones eléctricas y de fontanería que piden renovación completa.',
};

const reformaPhases = [
  { n: '01', title: 'Proyecto y permisos', desc: 'Antes de empezar la obra diseñamos la distribución en planos y tramitamos la licencia en el ayuntamiento si es necesaria. Sabes exactamente qué se va a hacer, dónde y con qué materiales antes de que entre un solo operario en tu casa.' },
  { n: '02', title: 'Derribo y redistribución', desc: 'La obra comienza con los derribos y la redistribución de tabiques. Es la fase más sucia pero también la más importante: una base mal ejecutada condiciona todo lo que viene después. Gestionamos la retirada de escombros incluida en el presupuesto.' },
  { n: '03', title: 'Instalaciones nuevas', desc: 'Fontanería, electricidad y calefacción desde cero o adaptadas a la nueva distribución. Cuadro eléctrico nuevo, circuitos diferenciados, tomas de agua y desagüe donde los necesitas. Todo bajo normativa vigente con boletines de legalización para la distribuidora.' },
  { n: '04', title: 'Revestimientos y pavimentos', desc: 'Alicatados, porcelánico, tarima y microcemento aplicados sobre soporte perfectamente preparado. Verificamos la nivelación y adherencia antes de colocar cualquier revestimiento para que el resultado dure décadas sin fisuras ni desprendimientos.' },
  { n: '05', title: 'Carpintería y acabados', desc: 'Puertas, armarios empotrados, ventanas, rodapiés y pintura final. Los acabados son lo que más se ve y lo que define el resultado. Aplicamos el mismo nivel de exigencia en la última capa de pintura que en la primera fase de derribo.' },
  { n: '06', title: 'Entrega con garantía de 2 años', desc: 'Limpieza final de obra, revisión completa y entrega con certificado de garantía de 2 años sobre toda la ejecución. Si algo falla por causas de nuestra ejecución en ese periodo, lo resolvemos sin coste adicional y sin discusiones.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout
  title="Trazzo360 | Reformas en el Corredor del Henares - Precio Cerrado desde 3.200€"
  description="Empresa de reformas integrales en el Corredor del Henares con precio cerrado garantizado. Alcalá de Henares, Torrejón, Coslada, San Fernando. Presupuesto gratis en 24h. Desde 3.200€."
  schema={faqSchema}
>

  <!-- HERO -->
  <section class="bg-[#111827] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 60px, rgba(255,255,255,0.05) 60px, rgba(255,255,255,0.05) 61px)"></div>
    <div class="relative max-w-7xl mx-auto px-4 py-28 lg:py-40">
      <div class="max-w-3xl">
        <div class="flex flex-wrap items-center gap-4 mb-6">
          <div class="flex items-center gap-3">
            <div class="w-8 h-0.5 bg-[#A85535]"></div>
            <span class="text-xs font-bold uppercase tracking-widest text-[#A85535]">Alcalá · Torrejón · Coslada · San Fernando · Guadalajara</span>
          </div>
          {SITE.reviewCount > 0 && (
            <a
              href={SITE.googleBusinessUrl || '#'}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 bg-white/10 border border-white/20 px-3 py-1.5 text-xs font-semibold text-white hover:bg-white/20 transition-colors"
            >
              <span class="text-yellow-400">{'★'.repeat(Math.round(SITE.ratingValue))}</span>
              <span>{SITE.ratingValue.toFixed(1)} · {SITE.reviewCount} reseñas en Google</span>
            </a>
          )}
        </div>
        <h1 class="text-5xl lg:text-7xl font-black text-white leading-none mb-6" style="letter-spacing:-0.02em">
          Empresa de <span class="text-[#A85535]">Reformas</span><br/>
          en el Corredor<br/>
          del Henares
        </h1>
        <p class="text-lg lg:text-xl text-gray-300 leading-relaxed mb-8 max-w-xl">
          En Trazzo360 sabes desde el primer día quién trabaja en tu vivienda, cuánto vas a pagar y cuándo termina la obra. Los profesionales que entran en tu casa llevan años trabajando con nosotros y aplican el mismo criterio en todos los proyectos. Precio cerrado, plazo garantizado y 2 años de garantía en todo lo ejecutado.
        </p>

        <!-- Trust signals -->
        <div class="flex flex-wrap gap-5 mb-10">
          {[
            { icon: '✓', text: 'Precio cerrado en contrato' },
            { icon: '⚡', text: 'Presupuesto en 24h' },
            { icon: '🛡', text: '2 años de garantía' },
            { icon: '🔑', text: 'Llave en mano' },
          ].map(item => (
            <div class="flex items-center gap-2">
              <span class="text-[#A85535] font-bold">{item.icon}</span>
              <span class="text-sm text-gray-300 font-medium">{item.text}</span>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto/" class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white hover:opacity-90 transition-opacity" style="background:#A85535">
            Pide Presupuesto Gratis
          </a>
          <a href={`tel:${SITE.phone}`} class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white border-2 border-white/30 hover:border-white transition-colors">
            ☎ {SITE.phoneDisplay}
          </a>
        </div>
        <p class="text-xs text-gray-500 mt-3">Sin visita previa · Respuesta en menos de 24h · Sin compromiso</p>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-white/10 bg-white/5">
      <div class="max-w-7xl mx-auto px-4 py-8 grid grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        {[
          { n: SITE.stats.projects, label: 'Obras realizadas' },
          { n: SITE.stats.years, label: 'Años en el sector' },
          { n: SITE.stats.cities, label: 'Municipios del Corredor' },
          { n: '100%', label: 'Precio cerrado garantizado' },
        ].map(s => (
          <div>
            <div class="text-4xl font-black text-[#A85535] mb-1">{s.n}</div>
            <div class="text-sm text-gray-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios" class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Nuestros servicios</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">¿Qué quieres reformar?</h2>
        <div class="w-12 h-1 bg-[#A85535] mb-5"></div>
        <p class="text-lg text-gray-500 max-w-xl">Reformas integrales y parciales en Alcalá de Henares, Torrejón de Ardoz, Coslada y toda la zona del Corredor del Henares.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {SERVICES.map(s => (
          <a href={`/servicios/${s.slug}/`}
            class="group block p-8 bg-gray-50 border-b-4 border-transparent hover:border-[#A85535] hover:shadow-xl hover:-translate-y-1 transition-all duration-200">
            <div class="text-4xl mb-5">{s.icon}</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">{s.desc}</p>
            <p class="text-xs font-bold text-gray-400 mb-4">Desde <span class="text-[#A85535] text-base font-black">{s.priceFrom}€</span></p>
            <span class="text-sm font-bold text-[#A85535] flex items-center gap-1 group-hover:gap-2 transition-all">
              {s.anchorLabel} en el Corredor del Henares →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- OFICIOS -->
  <section class="py-20 bg-[#111827]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="mb-12">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Profesionales de confianza</p>
        <h2 class="text-3xl lg:text-4xl font-black text-white mb-4" style="letter-spacing:-0.02em">Todos los oficios de la reforma, el mismo criterio de trabajo</h2>
        <div class="w-12 h-1 bg-[#A85535] mb-5"></div>
        <p class="text-gray-300 max-w-2xl">Una reforma integral implica coordinar muchos gremios. En Trazzo360 nos encargamos de esa coordinación de principio a fin: albañiles, fontaneros, electricistas, carpinteros, pintores y soladores que trabajan con nosotros y comparten la misma forma de hacer las cosas. Tú hablas con un interlocutor; nosotros respondemos de todo.</p>
      </div>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
        {[
          { icon: '🧱', trade: 'Albañilería y tabiquería', desc: 'Derribos, redistribución de espacios y construcción de tabiques. Hacemos la obra sucia con rigor porque lo que no se ve importa tanto como lo que sí: una base mal ejecutada arruina los mejores acabados.' },
          { icon: '🔧', trade: 'Fontanería y saneamiento', desc: 'Instalaciones nuevas de suministro y saneamiento para baños y cocinas. Trabajamos con materiales que duran y dejamos todo accesible y registrable para facilitar cualquier mantenimiento futuro.' },
          { icon: '⚡', trade: 'Electricidad e iluminación', desc: 'Cuadro eléctrico nuevo, circuitos diferenciados y puntos de luz donde los necesitas. Cumplimos el reglamento electrotécnico y entregamos el boletín para la legalización ante la distribuidora.' },
          { icon: '🪵', trade: 'Carpintería y cerramientos', desc: 'Puertas, ventanas, armarios empotrados y tarimas. Instalamos con la precisión necesaria para que todo abra bien, cierre bien y aguante el paso de los años sin deformaciones ni holguras.' },
          { icon: '🪣', trade: 'Alicatados y pavimentos', desc: 'Cerámica, porcelánico, microcemento y tarima flotante. Preparamos el soporte antes de colocar porque sin una base perfectamente nivelada el mejor material acaba fallando antes de tiempo.' },
          { icon: '🎨', trade: 'Pintura y acabados finales', desc: 'El último paso de una reforma es el que más se ve y más se nota. Lijamos, masillamos y aplicamos con el cuidado que merece cada estancia. Sin manchas en rodapiés, sin bordes irregulares, sin descuidos.' },
          { icon: '📐', trade: 'Diseño y planimetría', desc: 'Antes de mover un tabique te mostramos en planos cómo va a quedar tu casa: distribución, arquitectura interior y criterios de decoración. El asesoramiento de espacios está incluido en el proyecto, sin coste adicional.' },
          { icon: '📋', trade: 'Licencias y permisos', desc: 'Tramitamos la licencia de obra o actividad en el ayuntamiento que corresponda. Sin colas, sin papeleos innecesarios. Tú te centras en el resultado; nosotros gestionamos la burocracia.' },
        ].map(t => (
          <div class="bg-white/5 border border-white/10 p-5 hover:border-[#A85535]/50 transition-colors">
            <div class="text-2xl mb-3">{t.icon}</div>
            <p class="text-sm font-bold text-white mb-2">{t.trade}</p>
            <p class="text-xs text-gray-400 leading-relaxed">{t.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROYECTOS ANTES/DESPUÉS -->
  <!-- Imágenes: añade tus fotos en /public/img/proyectos/{slug}-antes.jpg y -despues.jpg -->
  <section id="proyectos" class="py-24 lg:py-32 bg-[#F9F7F4]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Proyectos realizados</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">Antes y después</h2>
        <div class="w-12 h-1 bg-[#A85535] mb-5"></div>
        <p class="text-lg text-gray-500 max-w-xl">Proyectos reales en el Corredor del Henares, cada uno con precio cerrado y entrega en el plazo acordado.</p>
      </div>
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        {PROJECTS.map(p => (
          <div class="bg-white">
            <div class="grid grid-cols-2">
              <div class="relative aspect-[4/3] bg-gray-800 overflow-hidden group">
                <span class="absolute top-0 left-0 bg-black/70 text-white text-xs font-bold px-3 py-1.5 uppercase tracking-wider z-10">Antes</span>
                <img
                  src={p.imgBefore}
                  alt={`${p.title} antes - ${p.location}`}
                  class="w-full h-full object-cover opacity-0 group-[.has-img]:opacity-100 transition-opacity"
                  loading="lazy"
                  onload="this.closest('.group').classList.add('has-img')"
                />
                <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-gray-500">
                  <svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <p class="text-xs">Añadir foto</p>
                </div>
              </div>
              <div class="relative aspect-[4/3] bg-gray-600 overflow-hidden group">
                <span class="absolute top-0 left-0 text-white text-xs font-bold px-3 py-1.5 uppercase tracking-wider z-10" style="background:#A85535">Después</span>
                <img
                  src={p.imgAfter}
                  alt={`${p.title} después - ${p.location}`}
                  class="w-full h-full object-cover opacity-0 group-[.has-img]:opacity-100 transition-opacity"
                  loading="lazy"
                  onload="this.closest('.group').classList.add('has-img')"
                />
                <div class="absolute inset-0 flex flex-col items-center justify-center gap-2 text-gray-400">
                  <svg class="w-9 h-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
                  <p class="text-xs">Añadir foto</p>
                </div>
              </div>
            </div>
            <div class="p-6">
              <div class="flex items-start justify-between gap-3 mb-2">
                <h3 class="font-bold text-gray-900">{p.title}</h3>
                <span class="text-xs font-bold text-[#A85535] whitespace-nowrap">{p.service}</span>
              </div>
              <p class="text-sm text-gray-500 leading-relaxed mb-4">{p.desc}</p>
              <div class="flex flex-wrap gap-4 text-xs font-medium text-gray-400">
                <span>📍 {p.location}</span>
                <span>📐 {p.surface}</span>
                <span>⏱ {p.duration}</span>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="mt-12 text-center">
        <p class="text-sm text-gray-500 mb-6">¿Tienes un proyecto en mente?</p>
        <a href="/contacto/" class="inline-block px-10 py-4 text-sm font-bold uppercase tracking-widest text-white hover:opacity-90 transition-opacity" style="background:#A85535">
          Pide presupuesto gratis
        </a>
      </div>
    </div>
  </section>

  <!-- PRECIOS ORIENTATIVOS - captura intent de PAA -->
  <section class="py-20 bg-[#F9F7F4]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="mb-12">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Precios orientativos</p>
        <h2 class="text-3xl lg:text-4xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">
          ¿Cuánto cuesta una reforma<br/>en el Corredor del Henares?
        </h2>
        <div class="w-12 h-1 bg-[#A85535] mb-5"></div>
        <p class="text-gray-500 max-w-xl">Precios de referencia para 2025–2026 en Alcalá de Henares, Torrejón de Ardoz y toda la zona. El precio final depende del estado actual, superficie y materiales elegidos. Siempre con <strong class="text-gray-700">precio cerrado en el contrato</strong>.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {[
          { tipo: 'Reforma integral de piso', detalle: '70–90 m²', desde: '24.900', hasta: '45.000' },
          { tipo: 'Reforma integral de piso', detalle: '100 m²', desde: '30.000', hasta: '55.000' },
          { tipo: 'Reforma de baño completo', detalle: 'Con cambio de bañera a ducha', desde: '3.200', hasta: '7.500' },
          { tipo: 'Reforma de cocina', detalle: 'Muebles, encimera y electrodomésticos', desde: '5.500', hasta: '14.000' },
          { tipo: 'Local comercial', detalle: '50 m²', desde: '8.000', hasta: '20.000' },
          { tipo: 'Portal / comunidad de vecinos', detalle: 'Escalera y zonas comunes', desde: '4.900', hasta: '18.000' },
        ].map(p => (
          <div class="bg-white p-6 border border-gray-100">
            <p class="text-sm font-bold text-gray-900 mb-1">{p.tipo}</p>
            <p class="text-xs text-gray-400 mb-3">{p.detalle}</p>
            <p class="text-2xl font-black text-[#A85535]">
              {p.desde}€ <span class="text-lg font-normal text-gray-400">– {p.hasta}€</span>
            </p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-xs text-gray-400">* Precios orientativos IVA incluido. El presupuesto personalizado y gratuito es siempre más preciso.</p>
      <a href="/contacto/" class="inline-block mt-6 px-8 py-3.5 text-sm font-bold uppercase tracking-widest text-white hover:opacity-90 transition-opacity" style="background:#A85535">
        Pide tu presupuesto cerrado
      </a>
    </div>
  </section>

  <!-- QUÉ CUBRE UNA REFORMA INTEGRAL -->
  <section class="py-24 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">De los planos a las llaves</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">Qué cubre una reforma integral de vivienda</h2>
        <div class="w-12 h-1 bg-[#A85535] mb-5"></div>
        <p class="text-lg text-gray-500 max-w-2xl">Una reforma integral no es solo pintar y cambiar azulejos. Implica coordinar varias fases con distintos gremios y plazos. Esto es lo que ocurre en cada proyecto, desde que firmas el presupuesto hasta que recibes las llaves.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {reformaPhases.map(phase => (
          <div class="border border-gray-100 p-7 hover:border-[#A85535]/30 transition-colors">
            <div class="text-4xl font-black text-[#A85535]/20 mb-3">{phase.n}</div>
            <h3 class="text-base font-bold text-gray-900 mb-3">{phase.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{phase.desc}</p>
          </div>
        ))}
      </div>
      <div class="mt-10 p-6 bg-[#F9F7F4] border-l-4 border-[#A85535]">
        <p class="text-sm text-gray-600 leading-relaxed">
          <strong class="text-gray-900">Precio cerrado desde el primer presupuesto:</strong> cada fase queda reflejada con su coste en el contrato que firmas. Si durante la obra aparece algo imprevisto que no estaba en el presupuesto, te lo comunicamos antes de actuar. Nunca después.
        </p>
      </div>
    </div>
  </section>

  <!-- POR QUÉ NOSOTROS -->
  <section id="nosotros" class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Por qué elegir Trazzo360</p>
          <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-6" style="letter-spacing:-0.02em">
            Reformas del hogar con precio cerrado<br/>y plazo garantizado
          </h2>
          <div class="w-12 h-1 bg-[#A85535] mb-6"></div>
          <p class="text-gray-500 leading-relaxed mb-8">Trazzo360 es una empresa de construcción y reformas del Corredor del Henares nacida con una convicción: las reformas pueden hacerse mejor. Con presupuestos que no cambian, plazos que se respetan y profesionales que tratan tu vivienda con el mismo cuidado con el que tratarían la suya. No trabajamos con cualquiera: quienes ejecutan tus proyectos llevan años trabajando con nosotros y aplican el mismo nivel de exigencia en cada obra, sea grande o pequeña.</p>
          <div class="space-y-6">
            {[
              { title: 'Precio cerrado por contrato', desc: 'El presupuesto que firmas es el que pagas. Sin extras de última hora, sin modificados no comunicados. Si durante la obra aparece algo imprevisto, te lo decimos antes de actuar, nunca después.' },
              { title: 'Plazo garantizado por escrito', desc: 'La fecha de entrega queda recogida en el contrato. Si por alguna causa propia nos retrasamos, compensamos económicamente. Sin excusas, sin semanas de silencio.' },
              { title: 'Profesionales de confianza', desc: 'No trabajamos con cualquiera. Quienes entran en tu vivienda llevan años trabajando con nosotros y comparten el mismo criterio: hacerlo bien desde la primera vez, como si fuera para ellos.' },
              { title: 'Pago por fases verificadas', desc: 'Pagas según avanza la obra, no todo por adelantado. En cada fase sabes exactamente qué se ha ejecutado, qué materiales se han colocado y qué queda por hacer.' },
              { title: '2 años de garantía en la ejecución', desc: 'Toda la obra que ejecutamos está garantizada por escrito durante 2 años. Si algo falla por causas de ejecución, lo resolvemos sin coste adicional y sin discusiones.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-6 h-6 rounded-full bg-[#A85535] flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 mb-1">{item.title}</h3>
                  <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-[#111827] p-10 text-white">
          <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-6">Nuestros números</p>
          <div class="grid grid-cols-2 gap-8">
            {[
              { n: SITE.stats.projects, label: 'Obras completadas' },
              { n: SITE.stats.years, label: 'Años de experiencia' },
              { n: SITE.stats.cities, label: 'Municipios cubiertos' },
              { n: '100%', label: 'Precio cerrado siempre' },
            ].map(s => (
              <div>
                <div class="text-5xl font-black text-[#A85535] mb-2">{s.n}</div>
                <div class="text-sm text-gray-400">{s.label}</div>
              </div>
            ))}
          </div>
          <a href="/contacto/" class="inline-block mt-10 px-7 py-3.5 text-sm font-bold uppercase tracking-widest text-white hover:opacity-90 transition-opacity" style="background:#A85535">
            Pedir presupuesto gratis
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIOS -->
  <!-- Reemplaza estos textos con citas reales de tus clientes -->
  <section class="py-24 lg:py-32 bg-[#F9F7F4]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Clientes</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">
          Lo que dicen quienes<br/>ya reformaron con nosotros
        </h2>
        <div class="w-12 h-1 bg-[#A85535] mx-auto"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        {TESTIMONIALS.map(t => (
          <div class="bg-white p-8 border border-gray-100 hover:border-[#A85535]/30 transition-colors">
            <div class="flex items-center gap-4 mb-5">
              <div class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0 font-bold text-sm text-white" style="background:#A85535">
                {t.initials}
              </div>
              <div class="flex-1 min-w-0">
                <p class="font-bold text-gray-900 text-sm">{t.name}</p>
                <p class="text-xs text-gray-400">{t.role} · {t.city}</p>
              </div>
              <div class="text-yellow-400 text-base flex-shrink-0">★★★★★</div>
            </div>
            <p class="text-xs font-bold text-[#A85535] bg-orange-50 inline-block px-2 py-1 mb-4">{t.service}</p>
            <p class="text-sm text-gray-600 leading-relaxed">"{t.text}"</p>
          </div>
        ))}
      </div>
      {SITE.googleBusinessUrl && (
        <p class="text-center text-sm text-gray-400 mt-8">
          ¿Ya trabajaste con nosotros?{' '}
          <a href={SITE.googleBusinessUrl} target="_blank" rel="noopener noreferrer" class="text-[#A85535] hover:underline font-medium">
            Deja tu reseña en Google →
          </a>
        </p>
      )}
    </div>
  </section>

  <!-- PROCESO -->
  <section id="proceso" class="py-24 lg:py-32 bg-[#F9F7F4]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Cómo trabajamos</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">Tu reforma en el Corredor, paso a paso</h2>
        <div class="w-12 h-1 bg-[#A85535] mx-auto"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { n: '01', title: 'Visita gratuita', desc: 'Visitamos tu vivienda en Alcalá, Torrejón, Coslada o cualquier municipio del Corredor sin ningún coste ni compromiso. Evaluamos el estado real de las instalaciones, tomamos medidas y escuchamos exactamente lo que quieres conseguir.' },
          { n: '02', title: 'Presupuesto cerrado', desc: 'En 24 a 48 horas recibes un presupuesto detallado con el precio final y el plazo de entrega cerrados. Sin letra pequeña, sin partidas abiertas. Lo que aparece en el documento que firmas es lo que vas a pagar.' },
          { n: '03', title: 'Ejecución con seguimiento', desc: 'Albañiles, fontaneros, electricistas y carpinteros ejecutan la obra con seguimiento diario y comunicación constante. Sabes en todo momento en qué punto está tu reforma y qué viene a continuación.' },
          { n: '04', title: 'Entrega con garantía', desc: 'Entregamos la obra limpia, revisada y en el plazo acordado. Recibes un certificado de garantía de 2 años sobre toda la ejecución. Si en ese periodo algo falla por nuestra parte, lo solucionamos.' },
        ].map(step => (
          <div class="text-center">
            <div class="text-6xl font-black text-[#A85535]/20 mb-4">{step.n}</div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{step.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ZONAS -->
  <section id="zonas" class="py-24 lg:py-32 bg-[#111827]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Zona de actuación</p>
        <h2 class="text-4xl lg:text-5xl font-black text-white mb-4" style="letter-spacing:-0.02em">
          Reformamos en<br/>todo el Corredor
        </h2>
        <div class="w-12 h-1 bg-[#A85535] mx-auto mb-6"></div>
        <p class="text-lg text-gray-300 max-w-2xl mx-auto">
          Cubrimos {SITE.stats.cities} municipios entre Madrid y Guadalajara. Profesionales de confianza en toda la zona, sin costes de desplazamiento y con respuesta en menos de 24h.
        </p>
      </div>

      <!-- Zonas primarias con H3 -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5 mb-8">
        {ZONES.filter(z => z.primary).map(z => (
          <a href={`/zonas/${z.slug}/`}
            class="block bg-white/5 border border-white/10 p-7 hover:border-[#A85535]/50 transition-all group">
            <h3 class="text-xl font-bold text-white mb-3 group-hover:text-[#A85535] transition-colors">Empresa de reformas en {z.name}</h3>
            <p class="text-sm text-gray-400 leading-relaxed mb-5">{primaryZoneDescs[z.slug]}</p>
            <span class="text-xs font-bold text-[#A85535] uppercase tracking-widest">Ver todos los servicios en {z.name} →</span>
          </a>
        ))}
      </div>

      <!-- Zonas secundarias -->
      <div class="border-t border-white/10 pt-8 mb-10">
        <p class="text-xs font-bold uppercase tracking-widest text-gray-500 mb-4">También cubrimos</p>
        <div class="flex flex-wrap gap-2">
          {ZONES.filter(z => !z.primary).map(z => (
            <a href={`/zonas/${z.slug}/`}
              class="inline-block px-4 py-2.5 text-sm font-medium text-gray-300 border border-white/20 hover:border-[#A85535]/50 hover:text-white transition-colors"
              style="background:rgba(255,255,255,0.04)">
              Obras y reformas en {z.name}
            </a>
          ))}
        </div>
      </div>

      <!-- CTA -->
      <div class="text-center">
        <a href="/contacto/" class="inline-block px-8 py-4 text-sm font-bold uppercase tracking-widest text-white hover:opacity-90 transition-opacity" style="background:#A85535">
          Pide presupuesto en tu zona
        </a>
        <p class="mt-3 text-sm text-gray-500">¿Tu municipio no aparece? Consúltanos, cubrimos zonas adyacentes.</p>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-24 lg:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Preguntas frecuentes</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">Precios y dudas sobre<br/>reformas en el Corredor del Henares</h2>
        <div class="w-12 h-1 bg-[#A85535] mx-auto"></div>
      </div>
      <div class="divide-y divide-gray-100">
        {faqs.map(faq => (
          <details class="group py-5">
            <summary class="flex justify-between items-start gap-4 cursor-pointer list-none font-semibold text-gray-900">
              {faq.q}
              <span class="text-[#A85535] text-2xl leading-none flex-shrink-0 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-gray-500 leading-relaxed text-sm">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-20 bg-[#A85535]">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl lg:text-5xl font-black text-white mb-4" style="letter-spacing:-0.02em">¿Listo para reformar?</h2>
      <p class="text-white/80 text-lg mb-8">Presupuesto gratuito en 24h. Precio cerrado. Sin sorpresas.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto/" class="inline-block px-10 py-4 font-bold text-sm uppercase tracking-widest bg-white text-[#A85535] hover:bg-gray-100 transition-colors">
          Pide Presupuesto Gratis
        </a>
        <a href={`tel:${SITE.phone}`} class="inline-block px-10 py-4 font-bold text-sm uppercase tracking-widest text-white border-2 border-white/50 hover:border-white transition-colors">
          ☎ {SITE.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

</Layout>
