---
import Layout from '../../layouts/Layout.astro';
import { SITE, SERVICES, ZONES } from '../../data/site';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () =>
  SERVICES.map(s => ({ params: { slug: s.slug }, props: { service: s } }));

const { service } = Astro.props;

const serviceGerund: Record<string, string> = {
  'reformas-integrales': 'reformas integrales',
  'reforma-banos':       'reformas de baños',
  'reforma-cocinas':     'reformas de cocinas',
  'reforma-pisos':       'reformas de pisos y chalets',
  'locales-comerciales': 'reformas de locales comerciales',
  'comunidades-vecinos': 'obras en comunidades de vecinos',
};
const serviceNecesitas: Record<string, string> = {
  'reformas-integrales': 'reformas integrales',
  'reforma-banos':       'reforma de baños',
  'reforma-cocinas':     'reforma de cocinas',
  'reforma-pisos':       'reforma de pisos y chalets',
  'locales-comerciales': 'reformar un local comercial',
  'comunidades-vecinos': 'obras para tu comunidad de vecinos',
};
const gerund    = serviceGerund[service.slug]    ?? service.title.toLowerCase();
const necesitas = serviceNecesitas[service.slug] ?? service.title.toLowerCase();

const serviceSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.title} en el Corredor del Henares`,
  description: service.desc,
  provider: {
    '@type': 'LocalBusiness',
    '@id': `${SITE.url}/#business`,
    name: SITE.name,
  },
  areaServed: ZONES.map(z => z.name),
  offers: {
    '@type': 'Offer',
    price: service.priceFrom,
    priceCurrency: 'EUR',
    description: service.priceDesc,
  },
};

const faqSchema = service.faqs.length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: service.faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
} : null;
---

<Layout
  title={`${service.title} en el Corredor del Henares | ${SITE.name}`}
  description={`${service.headline} Especialistas en ${gerund} en Alcalá de Henares, Torrejón de Ardoz, Coslada y todo el Corredor del Henares. Presupuesto gratis en 24h.`}
  schema={faqSchema ? [serviceSchema, faqSchema] : serviceSchema}
>

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 py-3 text-sm text-gray-500 flex items-center gap-2">
      <a href="/" class="hover:text-[#A85535] transition-colors">Inicio</a>
      <span class="text-gray-300">/</span>
      <a href="/#servicios" class="hover:text-[#A85535] transition-colors">Servicios</a>
      <span class="text-gray-300">/</span>
      <span class="text-gray-800 font-medium">{service.title}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-[#111827] py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-0.5 bg-[#A85535]"></div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#A85535]">{SITE.zone}</span>
        </div>
        <h1 class="text-4xl lg:text-6xl font-black text-white mb-5" style="letter-spacing:-0.02em">
          {service.title}<br/>
          <span class="text-[#A85535]">en el Corredor del Henares</span>
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-4">{service.headline}</p>
        {(service as any).heroCopy && (
          <p class="text-base text-gray-400 leading-relaxed mb-6">{(service as any).heroCopy}</p>
        )}
        <p class="text-sm text-gray-400 mb-8">
          Desde <span class="text-white font-black text-2xl">{service.priceFrom}€</span>
          <span class="ml-1">· {service.priceDesc}</span>
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto/" class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white hover:opacity-90 transition-opacity" style="background:#A85535">
            Presupuesto Gratis
          </a>
          <a href={`tel:${SITE.phone}`} class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white border-2 border-white/30 hover:border-white transition-colors">
            ☎ {SITE.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Descripción -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-black text-gray-900 mb-4">
          {service.title} en el Corredor del Henares
        </h2>
        {service.body ? (
          (service.body as string[]).map((p: string) => (
            <p class="text-gray-600 leading-relaxed mb-4">{p}</p>
          ))
        ) : (
          <p class="text-gray-600 leading-relaxed mb-6">{service.desc}</p>
        )}
        <p class="text-gray-600 leading-relaxed mb-6">
          En Trazzo360 llevamos {SITE.stats.years} años realizando {gerund} en todos los municipios del Corredor del Henares.
          Trabajamos con equipo propio, precio cerrado en el contrato y plazo de entrega garantizado.
        </p>
        <div class="grid grid-cols-2 gap-4">
          {['Precio cerrado por contrato', 'Equipo propio, sin subcontratas', 'Plazo de entrega garantizado', 'Presupuesto gratuito en 24h'].map(item => (
            <div class="flex items-center gap-3 p-4 bg-gray-50">
              <div class="w-5 h-5 rounded-full bg-[#A85535] flex items-center justify-center flex-shrink-0">
                <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-sm font-medium text-gray-800">{item}</span>
            </div>
          ))}
        </div>
      </div>
      <!-- Sidebar CTA -->
      <div class="bg-[#111827] p-8 text-white h-fit">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-4">Presupuesto gratis</p>
        <p class="text-2xl font-black mb-2">Desde <span class="text-[#A85535]">{service.priceFrom}€</span></p>
        <p class="text-sm text-gray-400 mb-6">{service.priceDesc}</p>
        <a href="/contacto/" class="block text-center py-3.5 font-bold text-sm uppercase tracking-widest text-white hover:opacity-90 transition-opacity mb-4" style="background:#A85535">
          Pedir presupuesto
        </a>
        <a href={`tel:${SITE.phone}`} class="block text-center py-3.5 text-sm font-semibold text-gray-300 border border-white/20 hover:border-white transition-colors">
          ☎ {SITE.phoneDisplay}
        </a>
        <p class="text-xs text-gray-500 mt-4 text-center">Visita gratuita · Sin compromiso</p>
      </div>
    </div>
  </section>

  <!-- Proceso paso a paso -->
  {service.processSteps && (service.processSteps as {title:string;desc:string}[]).length > 0 && (
    <section class="py-20 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-2xl font-black text-gray-900 mb-4">
          Cómo trabajamos: plazos reales, precio cerrado, sin sorpresas
        </h2>
        <p class="text-gray-600 leading-relaxed mb-10">
          Sabemos que iniciar una obra implica confiar en quien te la va a ejecutar. Por eso nuestro proceso está diseñado para que tengas certeza en cada fase: sabes cuándo empieza, cuándo termina y cuánto cuesta desde el primer día. Así organizamos cada proyecto de {gerund} en el Corredor del Henares, sin imprevistos ni cambios de precio a mitad de obra.
        </p>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {(service.processSteps as {title:string;desc:string}[]).map((step, i) => (
            <div class="flex gap-4 p-6 bg-white border border-gray-100">
              <div class="w-8 h-8 bg-[#A85535] text-white text-sm font-black flex items-center justify-center flex-shrink-0">
                {i + 1}
              </div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1 text-sm">{step.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Precios orientativos -->
  {service.priceTable && (service.priceTable as {label:string;price:string;includes?:string}[]).length > 0 && (
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl font-black text-gray-900 mb-4">
          ¿Cuánto cuesta {gerund} en el Corredor del Henares?
        </h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          Los precios que ves a continuación son orientativos, calculados sobre proyectos reales que hemos ejecutado en la zona. El presupuesto exacto depende del estado previo de tu vivienda o local, los materiales que elijas y el alcance de la obra. Visita gratuita y presupuesto cerrado en 48 horas, sin ningún compromiso.
        </p>
        <div class="divide-y divide-gray-100 border border-gray-100">
          {(service.priceTable as {label:string;price:string;includes?:string}[]).map(row => (
            <div class="flex items-center justify-between p-5 gap-6 hover:bg-gray-50 transition-colors">
              <div>
                <p class="font-semibold text-gray-900 text-sm">{row.label}</p>
                {row.includes && <p class="text-xs text-gray-400 mt-0.5">{row.includes}</p>}
              </div>
              <p class="text-[#A85535] font-black text-base flex-shrink-0">{row.price}</p>
            </div>
          ))}
        </div>
        <p class="text-xs text-gray-400 mt-4">* Precios orientativos. El precio exacto depende del estado previo, materiales y alcance de la obra. <a href="/contacto/" class="underline hover:text-[#A85535]">Solicita presupuesto gratuito.</a></p>
      </div>
    </section>
  )}

  <!-- Zonas donde ofrecemos este servicio -->
  <section class="py-16 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-2xl font-black text-gray-900 mb-4">
        Zona de actuación: todos los municipios del Corredor
      </h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Trabajamos en todos los municipios del Corredor del Henares sin coste de desplazamiento adicional. Tanto si tu vivienda, local o comunidad está en el núcleo urbano como en una urbanización, cubrimos toda la zona. Haz clic en tu municipio para ver los servicios disponibles y precios específicos.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-3">
        {ZONES.map(z => (
          <a href={`/${service.slug}/${z.slug}/`}
            class="block p-4 bg-white border border-gray-100 hover:border-[#A85535] hover:shadow-md transition-all group">
            <p class="font-semibold text-gray-800 group-hover:text-[#A85535] transition-colors text-sm">{z.name}</p>
            <p class="text-xs text-gray-400 mt-1 group-hover:text-[#A85535]/70 transition-colors">{service.shortTitle} en {z.name} →</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  {service.faqs.length > 0 && (
    <section class="py-20 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-2xl font-black text-gray-900 mb-4">Todo lo que necesitas saber antes de pedir presupuesto</h2>
        <p class="text-gray-600 leading-relaxed mb-8">
          Es normal tener dudas sobre plazos, precios, licencias y qué incluye exactamente la obra. A continuación respondemos las preguntas que más nos hacen antes de contratar. Si no encuentras la tuya, llámanos o escríbenos por WhatsApp y te respondemos el mismo día.
        </p>
        <div class="divide-y divide-gray-100">
          {service.faqs.map(faq => (
            <details class="group py-5">
              <summary class="flex justify-between items-start gap-4 cursor-pointer list-none font-semibold text-gray-900">
                {faq.q}
                <span class="text-[#A85535] text-2xl leading-none flex-shrink-0 group-open:rotate-45 transition-transform">+</span>
              </summary>
              <p class="mt-4 text-gray-500 leading-relaxed text-sm">{faq.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA Final -->
  <section class="py-16 bg-[#A85535]">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-white mb-3">¿Necesitas {necesitas} en el Corredor del Henares?</h2>
      <p class="text-white/80 mb-7">Presupuesto gratuito en 24h. Precio cerrado. Sin sorpresas.</p>
      <a href="/contacto/" class="inline-block px-10 py-4 font-bold text-sm uppercase tracking-widest bg-white text-[#A85535] hover:bg-gray-100 transition-colors">
        Pide Presupuesto Gratis
      </a>
    </div>
  </section>

</Layout>
