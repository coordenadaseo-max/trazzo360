---
import Layout from '../layouts/Layout.astro';
import { SITE } from '../data/site';
---

<Layout
  title={`Solicitud recibida | ${SITE.name}`}
  description="Hemos recibido tu solicitud de presupuesto. Te contactamos en menos de 24 horas."
>
  <section class="py-32 lg:py-48 bg-white text-center">
    <div class="max-w-xl mx-auto px-4">
      <div class="w-16 h-16 rounded-full bg-[#A85535] flex items-center justify-center mx-auto mb-8">
        <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h1 class="text-4xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">¡Solicitud recibida!</h1>
      <p class="text-lg text-gray-500 mb-2">Te contactamos en menos de 24 horas con tu presupuesto cerrado.</p>
      <p class="text-sm text-gray-400 mb-10">Si tienes urgencia, llámanos directamente.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/" class="inline-block px-8 py-3.5 text-sm font-bold uppercase tracking-widest text-white hover:opacity-90 transition-opacity" style="background:#A85535">
          Volver al inicio
        </a>
        {SITE.phone !== 'TU_TELEFONO' && (
          <a href={`tel:${SITE.phone}`} class="inline-block px-8 py-3.5 text-sm font-bold uppercase tracking-widest text-gray-800 border-2 border-gray-200 hover:border-[#A85535] transition-colors">
            ☎ {SITE.phoneDisplay}
          </a>
        )}
      </div>
    </div>
  </section>
</Layout>
