---
import { SITE, SERVICES, ZONES } from '../data/site';
---

<!-- Top bar -->
<div class="bg-[#111827] text-white text-sm py-2 text-center">
  <div class="max-w-7xl mx-auto px-4 flex flex-wrap justify-center gap-x-6 gap-y-1">
    <a href={`tel:${SITE.phone}`} class="hover:text-orange-300 transition-colors font-medium">
      ☎ {SITE.phoneDisplay}
    </a>
    <span class="opacity-40">|</span>
    <span>{SITE.hours}</span>
    <span class="opacity-40">|</span>
    <span>Presupuesto gratis en 24h</span>
  </div>
</div>

<!-- Main header -->
<header class="bg-white border-b border-gray-100 sticky top-0 z-50 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 flex items-center justify-between h-18 py-3">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2 flex-shrink-0">
      <span class="text-2xl font-black tracking-tight" style="color:#A85535">Trazzo<span class="text-gray-900">360</span></span>
    </a>

    <!-- Desktop nav -->
    <nav class="hidden lg:flex items-center gap-8 text-sm font-semibold uppercase tracking-wider">
      <!-- Servicios dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 text-gray-800 hover:text-[#A85535] transition-colors py-6">
          Reformas
          <svg class="w-3 h-3 mt-0.5" fill="none" viewBox="0 0 12 12"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="absolute top-full left-0 bg-white border border-gray-100 shadow-xl w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
          {SERVICES.map(s => (
            <a href={`/servicios/${s.slug}/`} class="block px-5 py-3 text-gray-700 hover:bg-orange-50 hover:text-[#A85535] border-b border-gray-50 last:border-0 transition-colors text-sm">
              {s.title}
            </a>
          ))}
        </div>
      </div>

      <!-- Zonas dropdown -->
      <div class="relative group">
        <button class="flex items-center gap-1 text-gray-800 hover:text-[#A85535] transition-colors py-6">
          Zonas
          <svg class="w-3 h-3 mt-0.5" fill="none" viewBox="0 0 12 12"><path d="M2 4l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <div class="absolute top-full left-0 bg-white border border-gray-100 shadow-xl w-56 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-150 z-50">
          {ZONES.map(z => (
            <a href={`/zonas/${z.slug}/`} class="block px-5 py-3 text-gray-700 hover:bg-orange-50 hover:text-[#A85535] border-b border-gray-50 last:border-0 transition-colors text-sm">
              {z.name}
            </a>
          ))}
        </div>
      </div>

      <a href="/#proyectos" class="text-gray-800 hover:text-[#A85535] transition-colors">Proyectos</a>
      <a href="/#proceso" class="text-gray-800 hover:text-[#A85535] transition-colors">Nosotros</a>
      <a href="/contacto/" class="text-gray-800 hover:text-[#A85535] transition-colors">Contacto</a>
    </nav>

    <!-- CTAs -->
    <div class="hidden lg:flex items-center gap-3">
      <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener noreferrer"
        class="flex items-center gap-2 px-4 py-2.5 text-sm font-semibold text-white rounded-sm transition-opacity hover:opacity-90"
        style="background:#25D366">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        WhatsApp
      </a>
      <a href="/contacto/" class="px-5 py-2.5 text-sm font-bold tracking-wider uppercase text-white transition-opacity hover:opacity-90" style="background:#A85535">
        Presupuesto Gratis
      </a>
    </div>

    <!-- Mobile toggle -->
    <button id="menu-toggle" class="lg:hidden p-2 text-gray-800" aria-label="Abrir menú">
      <svg width="24" height="24" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
    </button>
  </div>

  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden lg:hidden border-t border-gray-100 bg-white">
    <div class="px-4 py-2 space-y-1">
      <p class="text-xs font-bold uppercase text-gray-400 px-3 pt-3 pb-1">Servicios</p>
      {SERVICES.map(s => (
        <a href={`/servicios/${s.slug}/`} class="block px-3 py-2 text-gray-700 hover:text-[#A85535] text-sm font-medium">{s.title}</a>
      ))}
      <p class="text-xs font-bold uppercase text-gray-400 px-3 pt-4 pb-1">Zonas</p>
      {ZONES.map(z => (
        <a href={`/zonas/${z.slug}/`} class="block px-3 py-2 text-gray-700 hover:text-[#A85535] text-sm font-medium">{z.name}</a>
      ))}
      <div class="pt-4 pb-3">
        <a href="/contacto/" class="block text-center py-3 font-bold text-sm tracking-wider uppercase text-white" style="background:#A85535">
          Presupuesto Gratis
        </a>
      </div>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
