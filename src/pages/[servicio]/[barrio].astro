---
import Layout from '../../layouts/Layout.astro';
import { SITE, SERVICES, ZONES } from '../../data/site';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () =>
  SERVICES.flatMap(s =>
    ZONES.map(z => ({
      params: { servicio: s.slug, barrio: z.slug },
      props: { service: s, zone: z },
    }))
  );

const { service, zone } = Astro.props;

const isPrimary = zone.primary;
const cityPresence = isPrimary
  ? `con equipo permanente en ${zone.name}`
  : `cubriendo regularmente ${zone.name} y la comarca`;

const serviceIntros: Record<string, string> = {
  'reformas-integrales': `Una reforma integral en ${zone.name} implica rediseñar la distribución, renovar todas las instalaciones y elegir los acabados de principio a fin. ${zone.name} ${zone.localAngle}: conocemos bien el tipo de vivienda que encontrarás aquí y sabemos qué soluciones dan mejor resultado en este mercado.`,
  'reforma-banos': `Reformar el baño en ${zone.name} es una de las inversiones con mejor retorno en vivienda residencial. ${zone.name} ${zone.localAngle}: trabajamos habitualmente en este tipo de viviendas y podemos darte un presupuesto cerrado muy ajustado al mercado local.`,
  'reforma-cocinas': `Una cocina nueva en ${zone.name} transforma el uso diario del espacio más importante de la vivienda. ${zone.name} ${zone.localAngle}: diseñamos y ejecutamos cocinas a medida adaptadas a las dimensiones y características reales de los pisos de esta zona.`,
  'reforma-pisos': `Reformar un piso en ${zone.name} -redistribuir espacios, cambiar suelos, renovar ventanas- requiere conocer la normativa municipal. ${zone.name} ${zone.localAngle}: tramitamos la licencia de obra en el ayuntamiento y ejecutamos cualquier tipo de reforma de distribución o acabados.`,
  'locales-comerciales': `Abrir un negocio en ${zone.name} empieza con una obra que cumpla la normativa de actividad del municipio. ${zone.name} ${zone.localAngle}: conocemos los requisitos del ayuntamiento y tramitamos la licencia de actividad para que no pierdas ni un día de apertura.`,
  'comunidades-vecinos': `Las comunidades de propietarios en ${zone.name} necesitan mantenimiento periódico de zonas comunes: escaleras, portales, fachadas y cubiertas. ${zone.name} ${zone.localAngle}: elaboramos presupuesto detallado para junta y ejecutamos la obra con las mínimas molestias a los vecinos.`,
};

const commonReforms: Record<string, string> = {
  'reformas-integrales': 'redistribución de tabiques, actualización completa de instalaciones eléctricas y de fontanería, y cambio de suelos y carpinterías',
  'reforma-banos': 'cambio de bañera por ducha de obra, renovación de alicatados con gran formato y sustitución de sanitarios y muebles de baño',
  'reforma-cocinas': 'muebles a medida con encimera de silestone o porcelánico, electrodomésticos integrados y apertura de espacio hacia el salón',
  'reforma-pisos': 'suelos de porcelánico o laminado, ventanas de aluminio con rotura de puente térmico y pintura completa con acabados a medida',
  'locales-comerciales': 'adecuación de locales para hostelería, comercio minorista y oficinas con tramitación de licencia de actividad incluida',
  'comunidades-vecinos': 'renovación de portales y escaleras, impermeabilización de cubiertas y rehabilitación de fachadas con aislamiento',
};

const serviceFeatures: Record<string, string[]> = {
  'reformas-integrales': ['Diseño personalizado sin coste extra', 'Gestión de licencias en ' + zone.name, 'Coordinación de todos los gremios', 'Entrega llave en mano'],
  'reforma-banos': ['Cambio de bañera por ducha', 'Alicatados y pavimentos nuevos', 'Fontanería y electricidad incluidas', 'Muebles y mampara a medida'],
  'reforma-cocinas': ['Muebles de cocina a medida', 'Encimeras y electrodomésticos', 'Fontanería y electricidad completa', 'Diseño 3D previo a la obra'],
  'reforma-pisos': ['Derribo y redistribución de tabiques', 'Suelos laminados, parquet o microcemento', 'Ventanas y carpintería de aluminio', 'Pintura y acabados completos'],
  'locales-comerciales': ['Proyecto técnico incluido', 'Tramitación licencia de actividad', 'Electricidad, fontanería y ventilación', 'Adecuación a normativa sectorial'],
  'comunidades-vecinos': ['Presupuesto para junta de propietarios', 'Trabajamos sin cortar el paso', 'Fachadas, portales y cubiertas', 'Coordinación con administrador de fincas'],
};

const faqLabel: Record<string, { costar: string; tardar: string; tipo: string }> = {
  'reformas-integrales': { costar: 'una reforma integral', tardar: 'una reforma integral', tipo: 'reforma integral' },
  'reforma-banos':       { costar: 'reformar un baño',          tardar: 'reformar un baño',          tipo: 'reforma de baño' },
  'reforma-cocinas':     { costar: 'reformar una cocina',       tardar: 'reformar una cocina',       tipo: 'reforma de cocina' },
  'reforma-pisos':       { costar: 'reformar un piso o chalet', tardar: 'reformar un piso',          tipo: 'reforma de piso' },
  'locales-comerciales': { costar: 'reformar un local comercial', tardar: 'reformar un local comercial', tipo: 'reforma de local comercial' },
  'comunidades-vecinos': { costar: 'una reforma de zonas comunes', tardar: 'una obra en zonas comunes', tipo: 'reforma en comunidades de vecinos' },
};
const lbl = faqLabel[service.slug] ?? { costar: service.title.toLowerCase(), tardar: service.title.toLowerCase(), tipo: service.title.toLowerCase() };

const faqs = [
  {
    q: `¿Cuánto cuesta ${lbl.costar} en ${zone.name}?`,
    a: `El precio de ${lbl.costar} en ${zone.name} parte desde ${service.priceFrom}€ (${service.priceDesc}). Damos precio cerrado en el contrato: el presupuesto firmado es el precio final, sin sorpresas.`,
  },
  {
    q: `¿Tenéis equipo propio en ${zone.name}?`,
    a: `Sí. Trazzo360 opera ${cityPresence}. No subcontratamos obra: todo el equipo es propio, lo que nos permite controlar la calidad y respetar los plazos acordados.`,
  },
  {
    q: `¿Cuánto tarda ${lbl.tardar} en ${zone.name}?`,
    a: `El plazo varía según el alcance. Fijamos la fecha de entrega en el contrato y la garantizamos. Consúltanos y te indicamos un plazo orientativo para tu proyecto en ${zone.name}.`,
  },
  {
    q: `¿Gestionáis los permisos en el ayuntamiento de ${zone.name}?`,
    a: `Sí, tramitamos la licencia de obra o actividad en el ayuntamiento correspondiente. Nos ocupamos de toda la burocracia para que no tengas que preocuparte de nada.`,
  },
  {
    q: `¿Qué tipo de ${lbl.tipo} es más habitual en ${zone.name}?`,
    a: `${zone.name} ${zone.localAngle}. Las solicitudes más frecuentes en este tipo de inmuebles son: ${commonReforms[service.slug] ?? 'actualización completa de instalaciones y acabados'}. Consúltanos y te orientamos sobre la solución más adecuada para tu caso concreto.`,
  },
];

const pageSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `${service.title} en ${zone.name}`,
  description: `${service.headline} Servicio en ${zone.name}. Precio cerrado, plazo garantizado y presupuesto gratis en 24h.`,
  provider: {
    '@type': 'GeneralContractor',
    '@id': `${SITE.url}/#business`,
    name: SITE.name,
  },
  areaServed: {
    '@type': 'PostalAddress',
    addressLocality: zone.name,
    addressRegion: 'Comunidad de Madrid',
    addressCountry: 'ES',
  },
  offers: {
    '@type': 'Offer',
    price: service.priceFrom,
    priceCurrency: 'EUR',
    description: service.priceDesc,
  },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: `${SITE.url}/` },
    { '@type': 'ListItem', position: 2, name: service.title, item: `${SITE.url}/servicios/${service.slug}/` },
    { '@type': 'ListItem', position: 3, name: zone.name, item: `${SITE.url}/${service.slug}/${zone.slug}/` },
  ],
};

const howToSchema = service.processSteps && (service.processSteps as {title:string;desc:string}[]).length > 0 ? {
  '@context': 'https://schema.org',
  '@type': 'HowTo',
  name: `Cómo hacemos ${service.title.toLowerCase()} en ${zone.name}`,
  step: (service.processSteps as {title:string;desc:string}[]).map((step, i) => ({
    '@type': 'HowToStep',
    position: i + 1,
    name: step.title,
    text: step.desc,
  })),
} : null;

const otherZones = ZONES.filter(z => z.slug !== zone.slug);
const otherServices = SERVICES.filter(s => s.slug !== service.slug);
const features = serviceFeatures[service.slug] ?? [];
const intro = serviceIntros[service.slug] ?? service.desc;
---

<Layout
  title={`${service.title} en ${zone.name} | Precio Cerrado | ${SITE.name}`}
  description={`${service.title} en ${zone.name} desde ${service.priceFrom}€. ${zone.name} ${zone.localAngle}. Equipo propio, precio cerrado y presupuesto gratis en 24h.`}
  schema={[pageSchema, faqSchema, breadcrumbSchema, ...(howToSchema ? [howToSchema] : [])]}
>

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 py-3 text-sm text-gray-500 flex items-center gap-2 flex-wrap">
      <a href="/" class="hover:text-[#A85535] transition-colors">Inicio</a>
      <span class="text-gray-300">/</span>
      <a href={`/servicios/${service.slug}/`} class="hover:text-[#A85535] transition-colors">{service.title}</a>
      <span class="text-gray-300">/</span>
      <span class="text-gray-800 font-medium">{zone.name}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-[#111827] py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-0.5 bg-[#A85535]"></div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#A85535]">{SITE.zone}</span>
        </div>
        <h1 class="text-4xl lg:text-6xl font-black text-white mb-5" style="letter-spacing:-0.02em">
          {service.title}<br/>
          <span class="text-[#A85535]">en {zone.name}</span>
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-4">{service.headline}</p>
        <p class="text-base text-gray-400 leading-relaxed mb-6">{intro}</p>
        <p class="text-sm text-gray-400 mb-8">
          Desde <span class="text-white font-black text-2xl">{service.priceFrom}€</span>
          <span class="ml-2 text-gray-500">· {service.priceDesc}</span>
        </p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto/" class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white hover:opacity-90 transition-opacity" style="background:#A85535">
            Presupuesto Gratis en {zone.name}
          </a>
          <a href={`tel:${SITE.phone}`} class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white border-2 border-white/30 hover:border-white transition-colors">
            ☎ {SITE.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Contenido principal -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12">
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-black text-gray-900 mb-3">
          {service.title} en {zone.name}: qué incluye y cómo funciona
        </h2>
        <div class="w-12 h-1 bg-[#A85535] mb-6"></div>

        {service.body ? (
          (service.body as {type: string; text: string}[]).map((block) =>
            block.type === 'h3' ? (
              <h3 class="text-lg font-bold text-gray-900 mt-8 mb-2">{block.text}</h3>
            ) : block.type === 'h4' ? (
              <h4 class="text-base font-semibold text-gray-800 mt-5 mb-1">{block.text}</h4>
            ) : (
              <p class="text-gray-600 leading-relaxed mb-4">{block.text}</p>
            )
          )
        ) : (
          <p class="text-gray-600 leading-relaxed mb-6">{service.desc}</p>
        )}

        <p class="text-gray-600 leading-relaxed mt-6 mb-8">
          Trazzo360 lleva {SITE.stats.years} años realizando {service.title.toLowerCase()} en {SITE.mainCity} y todos los municipios del Corredor del Henares, incluyendo {zone.name}.
          Trabajamos {cityPresence}, con precio cerrado en el contrato y plazo de entrega garantizado.
        </p>

        {features.length > 0 && (
          <div>
            <h3 class="text-lg font-black text-gray-900 mb-4">Qué incluye este servicio en {zone.name}</h3>
            <div class="grid sm:grid-cols-2 gap-3">
              {features.map(item => (
                <div class="flex items-center gap-3 p-4 bg-gray-50">
                  <div class="w-5 h-5 rounded-full bg-[#A85535] flex items-center justify-center flex-shrink-0">
                    <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                  </div>
                  <span class="text-sm font-medium text-gray-800">{item}</span>
                </div>
              ))}
            </div>
          </div>
        )}

        <div class="bg-[#F9F7F4] border-l-4 border-[#A85535] p-6 mt-8">
          <p class="text-sm font-semibold text-gray-900 mb-2">Antes de pedir presupuesto en {zone.name}</p>
          <p class="text-sm text-gray-600 leading-relaxed">
            Si el inmueble tiene más de 30 años, asegúrate de que el presupuesto evalúe el estado de las instalaciones antes de cerrar el precio. Un presupuesto que no las contempla puede quedarse obsoleto en cuanto empiece la obra. En Trazzo360 lo incluimos en la visita técnica gratuita, sin coste ni compromiso.
          </p>
        </div>
      </div>

      <!-- Sidebar CTA -->
      <div class="bg-[#111827] p-8 text-white h-fit sticky top-6">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-4">Presupuesto gratis</p>
        <p class="text-xl font-black mb-1">Desde <span class="text-[#A85535] text-3xl">{service.priceFrom}€</span></p>
        <p class="text-sm text-gray-400 mb-6">{service.priceDesc}</p>
        <a href="/contacto/" class="block text-center py-3.5 font-bold text-sm uppercase tracking-widest text-white hover:opacity-90 transition-opacity mb-3" style="background:#A85535">
          Pedir presupuesto
        </a>
        <a href={`tel:${SITE.phone}`} class="block text-center py-3.5 text-sm font-semibold text-gray-300 border border-white/20 hover:border-white transition-colors mb-4">
          ☎ {SITE.phoneDisplay}
        </a>
        <p class="text-xs text-gray-500 text-center">Respuesta en menos de 24h</p>
      </div>
    </div>
  </section>

  <!-- Por qué Trazzo360 -->
  <section class="py-16 bg-[#F9F7F4]">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-2xl font-black text-gray-900 mb-4">
          Por qué elegir Trazzo360 para {service.title.toLowerCase()} en {zone.name}
        </h2>
        <div class="w-12 h-1 bg-[#A85535] mb-6"></div>
        <div class="space-y-4">
          {[
            `Equipo propio ${cityPresence}. Sin subcontratas externas.`,
            'Precio cerrado en el contrato desde el primer presupuesto. Sin extras de última hora.',
            'Plazo de entrega garantizado por escrito. Con penalización si nos retrasamos sin causa de fuerza mayor.',
            'Visita técnica y presupuesto gratuitos. Sin compromiso ni presión.',
            `Más de ${SITE.stats.projects} obras completadas en el Corredor del Henares en ${SITE.stats.years} años.`,
            'Gestión de licencias y permisos de obra incluida cuando la normativa lo requiere.',
          ].map(item => (
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-[#A85535] flex items-center justify-center flex-shrink-0 mt-0.5">
                <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                </svg>
              </div>
              <span class="text-sm text-gray-700">{item}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-[#111827] p-8 text-white">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-4">Presupuesto gratuito</p>
        <p class="text-xl font-black text-white mb-2">Visita y precio en 24h</p>
        <p class="text-sm text-gray-400 mb-6">
          Sin compromiso. Cuéntanos qué quieres reformar en {zone.name} y te damos precio cerrado en menos de 48 horas.
        </p>
        <a href="/contacto/" class="block text-center py-3.5 font-bold text-sm uppercase tracking-widest text-white hover:opacity-90 transition-opacity mb-3" style="background:#A85535">
          Solicitar presupuesto en {zone.name}
        </a>
        <a href={`tel:${SITE.phone}`} class="block text-center py-3 text-sm text-gray-300 border border-white/20 hover:border-white transition-colors">
          ☎ {SITE.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- Proceso paso a paso -->
  {service.processSteps && (service.processSteps as {title:string;desc:string}[]).length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4">
        <h2 class="text-xl font-black text-gray-900 mb-3">
          Cómo trabajamos: {service.title.toLowerCase()} en {zone.name}
        </h2>
        <p class="text-gray-600 leading-relaxed mb-3 max-w-2xl">
          Plazos reales, precio cerrado y sin imprevistos. Así organizamos cada proyecto en {zone.name}, desde la visita técnica gratuita hasta la entrega con garantía de 2 años.
        </p>
        <div class="w-12 h-1 bg-[#A85535] mb-8"></div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {(service.processSteps as {title:string;desc:string}[]).map((step, i) => (
            <div class="flex gap-4 p-6 bg-gray-50 border border-gray-100">
              <div class="w-7 h-7 bg-[#A85535] text-white text-xs font-black flex items-center justify-center flex-shrink-0">
                {i + 1}
              </div>
              <div>
                <h3 class="font-bold text-gray-900 mb-1 text-sm">{step.title}</h3>
                <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Barrios y zonas donde actuamos -->
  <section class="py-12 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-lg font-black text-gray-900 mb-2">
        Zonas de {zone.name} donde trabajamos
      </h2>
      <p class="text-sm text-gray-500 mb-5">Cubrimos todos los barrios y urbanizaciones de {zone.name} sin recargo por desplazamiento.</p>
      <div class="flex flex-wrap gap-2">
        {zone.neighborhoods.map((n: string) => (
          <span class="inline-block px-3 py-1.5 bg-white border border-gray-200 text-sm text-gray-700 font-medium">
            {n}
          </span>
        ))}
        <span class="inline-block px-3 py-1.5 bg-white border border-dashed border-gray-300 text-sm text-gray-400">
          ¿Tu zona no aparece? Consúltanos igualmente
        </span>
      </div>
    </div>
  </section>

  <!-- Precios orientativos -->
  {service.priceTable && (service.priceTable as {label:string;price:string;includes?:string}[]).length > 0 && (
    <section class="py-16 bg-white">
      <div class="max-w-4xl mx-auto px-4">
        <h2 class="text-xl font-black text-gray-900 mb-3">
          ¿Cuánto cuesta {service.title.toLowerCase()} en {zone.name}?
        </h2>
        <p class="text-gray-600 leading-relaxed mb-3 max-w-2xl">
          Precios de referencia calculados sobre proyectos reales ejecutados en {zone.name} y el Corredor del Henares. El presupuesto exacto, cerrado y sin sorpresas, lo recibes gratis en 48h tras la visita técnica.
        </p>
        <div class="w-12 h-1 bg-[#A85535] mb-6"></div>
        <div class="divide-y divide-gray-100 border border-gray-100">
          {(service.priceTable as {label:string;price:string;includes?:string}[]).map(row => (
            <div class="flex items-center justify-between p-5 gap-6 hover:bg-gray-50 transition-colors">
              <div>
                <p class="font-semibold text-gray-900 text-sm">{row.label}</p>
                {row.includes && <p class="text-xs text-gray-400 mt-0.5">{row.includes}</p>}
              </div>
              <p class="text-[#A85535] font-black text-base flex-shrink-0">{row.price}</p>
            </div>
          ))}
        </div>
        <p class="text-xs text-gray-400 mt-4">* Precios orientativos IVA incluido. El precio exacto depende del estado previo, los materiales y el alcance de la obra. <a href="/contacto/" class="underline hover:text-[#A85535]">Solicita presupuesto gratuito.</a></p>
      </div>
    </section>
  )}

  <!-- Este servicio en otras ciudades -->
  <section class="py-14 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-lg font-black text-gray-900 mb-2">
        {service.title} en otras ciudades del Corredor
      </h2>
      <p class="text-sm text-gray-500 mb-5">
        Trabajamos en todos los municipios del Corredor del Henares con el mismo equipo propio, el mismo precio cerrado y el mismo compromiso de plazo. Sin coste adicional por desplazamiento.
      </p>
      <div class="flex flex-wrap gap-2">
        {otherZones.map(z => (
          <a href={`/${service.slug}/${z.slug}/`}
            class="inline-block px-4 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-200 hover:border-[#A85535] hover:text-[#A85535] transition-all">
            {service.anchorLabel} en {z.name}
          </a>
        ))}
      </div>
      <p class="text-sm text-gray-400 mt-4">
        También puedes ver la <a href={`/zonas/${zone.slug}/`} class="underline hover:text-[#A85535] transition-colors">página completa de {zone.name}</a> o todos los trabajos de <a href={`/servicios/${service.slug}/`} class="underline hover:text-[#A85535] transition-colors">{service.title.toLowerCase()}</a> que realizamos.
      </p>
    </div>
  </section>

  <!-- Otros servicios en esta ciudad -->
  <section class="py-14 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-lg font-black text-gray-900 mb-2">
        Otros servicios de reforma en {zone.name}
      </h2>
      <p class="text-sm text-gray-500 mb-5">
        En Trazzo360 cubrimos todos los tipos de obra en {zone.name} con el mismo equipo y el mismo compromiso de precio y plazo. Elige el servicio que necesitas.
      </p>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {otherServices.map(s => (
          <a href={`/${s.slug}/${zone.slug}/`}
            class="group block p-4 bg-gray-50 border-b-2 border-transparent hover:border-[#A85535] hover:shadow-sm transition-all">
            <span class="text-xl block mb-1">{s.icon}</span>
            <p class="text-sm font-semibold text-gray-800 group-hover:text-[#A85535] transition-colors">{s.title}</p>
            <p class="text-xs text-gray-400 mt-0.5">Desde {s.priceFrom}€</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-[#F9F7F4]">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-black text-gray-900 mb-4">
        Preguntas frecuentes: {service.title} en {zone.name}
      </h2>
      <p class="text-gray-600 leading-relaxed mb-8">
        Precios, plazos, permisos y qué incluye exactamente el servicio. Si no encuentras tu duda aquí, escríbenos por WhatsApp o llámanos y te respondemos el mismo día.
      </p>
      <div class="divide-y divide-gray-200">
        {faqs.map(faq => (
          <details class="group py-5">
            <summary class="flex justify-between items-start gap-4 cursor-pointer list-none">
              <h3 class="font-semibold text-gray-900 text-base leading-snug m-0">{faq.q}</h3>
              <span class="text-[#A85535] text-2xl leading-none flex-shrink-0 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-gray-500 leading-relaxed text-sm">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA final -->
  <section class="py-16 bg-[#A85535]">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-white mb-3">
        ¿{service.title} en {zone.name}?
      </h2>
      <p class="text-white/80 mb-7">Presupuesto gratuito en 24h. Precio cerrado. Equipo propio.</p>
      <a href="/contacto/" class="inline-block px-10 py-4 font-bold text-sm uppercase tracking-widest bg-white text-[#A85535] hover:bg-gray-100 transition-colors">
        Pide Presupuesto Gratis
      </a>
    </div>
  </section>

</Layout>
