---
import Layout from '../../layouts/Layout.astro';
import { SITE, SERVICES, ZONES } from '../../data/site';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () =>
  ZONES.map(z => ({ params: { slug: z.slug }, props: { zone: z } }));

const { zone } = Astro.props;

const faqs = [
  {
    q: `¿Hacéis reformas integrales en ${zone.name}?`,
    a: `Sí. Trazzo360 opera en ${zone.name} con equipo propio. Realizamos reformas integrales de pisos, baños, cocinas, locales y comunidades de vecinos. Presupuesto gratuito en 24h.`,
  },
  {
    q: `¿Cuánto cuesta una reforma en ${zone.name}?`,
    a: `Los precios dependen del tipo de obra y los materiales elegidos. En ${zone.name}, una reforma integral de piso de 70–90 m² oscila entre 24.900€ y 45.000€. Un baño completo parte desde 3.200€ y una cocina desde 5.500€. Damos precio cerrado en el contrato.`,
  },
  {
    q: `¿Qué tipo de reformas son más habituales en ${zone.name}?`,
    a: `${zone.name} ${zone.localAngle}. Por eso, los proyectos más frecuentes que llevamos a cabo aquí son renovaciones de baños y cocinas, actualizaciones de instalaciones y, en muchos casos, reformas integrales que aprovechan para redistribuir la planta.`,
  },
  {
    q: `¿Gestionáis los permisos de obra en ${zone.name}?`,
    a: `Sí. Tramitamos la licencia de obra o de actividad en el ayuntamiento de ${zone.name}. Nos encargamos de toda la burocracia para que solo tengas que preocuparte de los acabados finales.`,
  },
];

const zoneSchema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Reformas Integrales en ${zone.name}`,
  description: zone.desc,
  provider: {
    '@type': 'LocalBusiness',
    '@id': `${SITE.url}/#business`,
    name: SITE.name,
  },
  areaServed: { '@type': 'City', name: zone.name, containedInPlace: { '@type': 'AdministrativeArea', name: 'Comunidad de Madrid' } },
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout
  title={`Reformas Integrales en ${zone.name} | Precio Cerrado | ${SITE.name}`}
  description={`Empresa de reformas integrales en ${zone.name}. Baños, cocinas, pisos y locales. Precio cerrado, plazo garantizado y presupuesto gratis en 24h. Equipo propio en ${zone.name} y el Corredor del Henares.`}
  schema={[zoneSchema, faqSchema]}
>

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 py-3 text-sm text-gray-500 flex items-center gap-2">
      <a href="/" class="hover:text-[#A85535] transition-colors">Inicio</a>
      <span class="text-gray-300">/</span>
      <span class="hover:text-[#A85535] transition-colors cursor-pointer">Zonas</span>
      <span class="text-gray-300">/</span>
      <span class="text-gray-800 font-medium">{zone.name}</span>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-[#111827] py-20 lg:py-28">
    <div class="max-w-7xl mx-auto px-4">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-0.5 bg-[#A85535]"></div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#A85535]">{SITE.zone}</span>
        </div>
        <h1 class="text-4xl lg:text-6xl font-black text-white mb-5" style="letter-spacing:-0.02em">
          Reformas<br/>
          <span class="text-[#A85535]">Integrales</span><br/>
          en {zone.name}.
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-4">
          {zone.name} {zone.localAngle}. Trazzo360 trabaja aquí con equipo propio, precio cerrado en el contrato y plazo de entrega garantizado.
        </p>
        <p class="text-sm text-gray-400 mb-8">Presupuesto gratuito en menos de 24h · Sin visita previa obligatoria</p>
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto/" class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white hover:opacity-90 transition-opacity" style="background:#A85535">
            Presupuesto Gratis en {zone.name}
          </a>
          <a href={`tel:${SITE.phone}`} class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white border-2 border-white/30 hover:border-white transition-colors">
            ☎ {SITE.phoneDisplay}
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Servicios en esta zona -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-3xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">
        Servicios de reforma en {zone.name}
      </h2>
      <div class="w-12 h-1 bg-[#A85535] mb-10"></div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {SERVICES.map(s => (
          <a href={`/${s.slug}/${zone.slug}/`}
            class="group block p-7 bg-gray-50 border-b-4 border-transparent hover:border-[#A85535] hover:shadow-lg transition-all duration-200">
            <div class="text-3xl mb-4">{s.icon}</div>
            <h3 class="text-lg font-bold text-gray-900 mb-2">{s.title} en {zone.name}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-3">{s.desc}</p>
            <p class="text-xs font-bold text-gray-400">Desde <span class="text-[#A85535] text-sm font-black">{s.priceFrom}€</span></p>
            <span class="text-xs font-bold text-[#A85535] mt-2 block group-hover:underline">Ver {s.shortTitle} en {zone.name} →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Por qué Trazzo360 en esta zona -->
  <section class="py-16 bg-[#F9F7F4]">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <h2 class="text-2xl font-black text-gray-900 mb-6">¿Por qué elegir Trazzo360 en {zone.name}?</h2>
        <div class="space-y-4">
          {[
            `Equipo propio en ${zone.name} y todo el Corredor del Henares`,
            'Precio cerrado por contrato, sin extras ni sorpresas',
            'Plazo de entrega garantizado por escrito',
            'Más de ' + SITE.stats.projects + ' obras completadas en la zona',
            'Presupuesto gratuito en 24h sin visita previa',
          ].map(item => (
            <div class="flex items-center gap-3">
              <div class="w-5 h-5 rounded-full bg-[#A85535] flex items-center justify-center flex-shrink-0">
                <svg class="w-2.5 h-2.5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
              </div>
              <span class="text-sm text-gray-700">{item}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-[#111827] p-8 text-white">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-4">Solicita presupuesto</p>
        <p class="text-xl font-black text-white mb-2">Gratis y sin compromiso</p>
        <p class="text-sm text-gray-400 mb-6">Respondemos en menos de 24h</p>
        <a href="/contacto/" class="block text-center py-3.5 font-bold text-sm uppercase tracking-widest text-white hover:opacity-90 transition-opacity mb-3" style="background:#A85535">
          Pedir presupuesto en {zone.name}
        </a>
        <a href={`tel:${SITE.phone}`} class="block text-center py-3 text-sm text-gray-300 border border-white/20 hover:border-white transition-colors">
          ☎ {SITE.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

  <!-- Barrios donde actuamos -->
  <section class="py-12 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-xl font-black text-gray-900 mb-2">Barrios y zonas de {zone.name} donde trabajamos</h2>
      <p class="text-sm text-gray-500 mb-6">Cubrimos todos los barrios y urbanizaciones de {zone.name} sin coste adicional por desplazamiento.</p>
      <div class="flex flex-wrap gap-2">
        {zone.neighborhoods.map((n: string) => (
          <span class="inline-block px-4 py-2 bg-gray-50 border border-gray-200 text-sm text-gray-700 font-medium">
            {n}
          </span>
        ))}
        <span class="inline-block px-4 py-2 bg-gray-50 border border-dashed border-gray-300 text-sm text-gray-400">
          ¿Tu barrio no aparece? Consúltanos
        </span>
      </div>
    </div>
  </section>

  <!-- Otras zonas -->
  <section class="py-16 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <h2 class="text-xl font-black text-gray-900 mb-6">También reformamos en</h2>
      <div class="flex flex-wrap gap-2">
        {ZONES.filter(z => z.slug !== zone.slug).map(z => (
          <a href={`/zonas/${z.slug}/`}
            class="inline-block px-4 py-2 text-sm text-gray-600 bg-gray-100 hover:bg-[#A85535] hover:text-white transition-all font-medium">
            {z.name}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 bg-[#F9F7F4]">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-black text-gray-900 mb-8">Preguntas frecuentes sobre reformas en {zone.name}</h2>
      <div class="divide-y divide-gray-200">
        {faqs.map(faq => (
          <details class="group py-5">
            <summary class="flex justify-between items-start gap-4 cursor-pointer list-none font-semibold text-gray-900">
              {faq.q}
              <span class="text-[#A85535] text-2xl leading-none flex-shrink-0 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-gray-500 leading-relaxed text-sm">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Final -->
  <section class="py-16 bg-[#A85535]">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl font-black text-white mb-3">¿Reformas en {zone.name}?</h2>
      <p class="text-white/80 mb-7">Presupuesto gratuito en 24h. Precio cerrado. Equipo propio.</p>
      <a href="/contacto/" class="inline-block px-10 py-4 font-bold text-sm uppercase tracking-widest bg-white text-[#A85535] hover:bg-gray-100 transition-colors">
        Pide Presupuesto Gratis
      </a>
    </div>
  </section>

</Layout>
