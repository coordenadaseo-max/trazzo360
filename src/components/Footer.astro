---
import { SITE, SERVICES, ZONES } from '../data/site';
---

<footer class="bg-[#111827] text-gray-300">
  <div class="max-w-7xl mx-auto px-4 py-16 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">
    <!-- Brand -->
    <div>
      <a href="/" class="inline-block mb-4">
        <span class="text-2xl font-black tracking-tight" style="color:#A85535">Trazzo<span class="text-white">360</span></span>
      </a>
      <p class="text-sm text-gray-400 leading-relaxed mb-4">
        Empresa de reformas integrales en el Corredor del Henares. Precio cerrado, plazo garantizado.
      </p>
      <p class="text-sm text-gray-400">{SITE.hours}</p>
      <a href={`tel:${SITE.phone}`} class="block mt-2 text-white font-semibold hover:text-orange-400 transition-colors">
        {SITE.phoneDisplay}
      </a>
    </div>

    <!-- Servicios -->
    <div>
      <h3 class="text-white font-bold uppercase tracking-wider text-xs mb-4">Servicios</h3>
      <ul class="space-y-2">
        {SERVICES.map(s => (
          <li><a href={`/servicios/${s.slug}/`} class="text-sm text-gray-400 hover:text-orange-400 transition-colors">{s.title}</a></li>
        ))}
      </ul>
    </div>

    <!-- Zonas -->
    <div>
      <h3 class="text-white font-bold uppercase tracking-wider text-xs mb-4">Zonas</h3>
      <ul class="space-y-2">
        {ZONES.map(z => (
          <li><a href={`/zonas/${z.slug}/`} class="text-sm text-gray-400 hover:text-orange-400 transition-colors">{z.name}</a></li>
        ))}
      </ul>
    </div>

    <!-- Contacto -->
    <div>
      <h3 class="text-white font-bold uppercase tracking-wider text-xs mb-4">Contacto</h3>
      <ul class="space-y-3 text-sm text-gray-400">
        <li><a href={`tel:${SITE.phone}`} class="hover:text-orange-400 transition-colors">{SITE.phoneDisplay}</a></li>
        <li><a href={`mailto:${SITE.email}`} class="hover:text-orange-400 transition-colors">{SITE.email}</a></li>
        <li>{SITE.address}</li>
      </ul>
      <a href="/contacto/"
        class="inline-block mt-6 px-6 py-3 text-xs font-bold uppercase tracking-wider text-white transition-opacity hover:opacity-80"
        style="background:#A85535">
        Pide presupuesto gratis
      </a>
    </div>
  </div>

  <div class="border-t border-gray-800">
    <div class="max-w-7xl mx-auto px-4 py-5 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-gray-500">
      <p>© {new Date().getFullYear()} {SITE.name}. Todos los derechos reservados.</p>
      <nav class="flex gap-4">
        <a href="/privacidad/" class="hover:text-gray-300 transition-colors">Privacidad</a>
        <a href="/aviso-legal/" class="hover:text-gray-300 transition-colors">Aviso legal</a>
        <a href="/cookies/" class="hover:text-gray-300 transition-colors">Cookies</a>
      </nav>
    </div>
  </div>
</footer>
