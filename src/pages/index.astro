---
import Layout from '../layouts/Layout.astro';
import { SITE, SERVICES, ZONES } from '../data/site';

const faqs = [
  { q: '¿Cuánto cuesta una reforma integral en Alcalá de Henares?', a: 'Una reforma integral de un piso de 70–90 m² en el Corredor del Henares oscila entre 24.900€ y 45.000€ con materiales de calidad media-alta. Damos precio cerrado desde el primer día.' },
  { q: '¿Cuánto tarda una reforma integral?', a: 'Entre 8 y 14 semanas para un piso de 70–90 m². Fijamos la fecha de entrega en el contrato y la cumplimos.' },
  { q: '¿Necesito licencia de obra para reformar mi piso?', a: 'Depende del tipo de reforma. Obras menores (pintura, suelos, sanitarios) suelen necesitar solo comunicación previa. Si hay derribo de tabiques o redistribución de espacios se requiere licencia de obra mayor. Tramitamos todo en el ayuntamiento.' },
  { q: '¿Trabajáis en toda la zona del Corredor del Henares?', a: 'Sí. Cubrimos Alcalá de Henares, Torrejón de Ardoz, Coslada, San Fernando de Henares, Guadalajara, Azuqueca de Henares, Meco, Camarma de Esteruelas y municipios adyacentes.' },
  { q: '¿Cómo funciona el pago?', a: 'Trabajamos con pago por fases: inicio de obra, hitos intermedios verificados y pago final a la entrega. Nunca pedimos el total por adelantado.' },
  { q: '¿Hacéis reformas de comunidades de vecinos?', a: 'Sí. Zonas comunes, escaleras, portales, fachadas y cubiertas. Emitimos presupuesto detallado para presentar en junta de vecinos.' },
];

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map(f => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout
  title="Reformas Integrales en Alcalá de Henares y el Corredor del Henares | Trazzo360"
  description="Empresa de reformas integrales en Alcalá de Henares, Torrejón de Ardoz, Coslada y todo el Corredor del Henares. Precio cerrado, plazo garantizado y presupuesto gratis en 24h."
  schema={faqSchema}
>

  <!-- HERO -->
  <section class="bg-[#111827] relative overflow-hidden">
    <div class="absolute inset-0 opacity-10" style="background-image: repeating-linear-gradient(45deg, transparent, transparent 60px, rgba(255,255,255,0.05) 60px, rgba(255,255,255,0.05) 61px)"></div>
    <div class="relative max-w-7xl mx-auto px-4 py-28 lg:py-40">
      <div class="max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <div class="w-8 h-0.5 bg-[#A85535]"></div>
          <span class="text-xs font-bold uppercase tracking-widest text-[#A85535]">Corredor del Henares · Madrid</span>
        </div>
        <h1 class="text-5xl lg:text-7xl font-black text-white leading-none mb-6" style="letter-spacing:-0.02em">
          Reformas<br/>
          <span class="text-[#A85535]">Integrales</span><br/>
          en Alcalá de Henares<br/>
          <span class="text-3xl lg:text-4xl font-bold text-gray-300">y todo el Corredor.</span>
        </h1>
        <p class="text-lg lg:text-xl text-gray-300 leading-relaxed mb-8 max-w-xl">
          Precio cerrado desde el primer día. Plazo garantizado por contrato. Pago por fases. Sin sorpresas.
        </p>

        <!-- Trust signals -->
        <div class="flex flex-wrap gap-5 mb-10">
          {[
            { icon: '✓', text: 'Precio cerrado en contrato' },
            { icon: '⚡', text: 'Presupuesto en 24h' },
            { icon: '🛡', text: 'Seguro RC incluido' },
            { icon: '🔑', text: 'Llave en mano' },
          ].map(item => (
            <div class="flex items-center gap-2">
              <span class="text-[#A85535] font-bold">{item.icon}</span>
              <span class="text-sm text-gray-300 font-medium">{item.text}</span>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row gap-4">
          <a href="/contacto/" class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white hover:opacity-90 transition-opacity" style="background:#A85535">
            Pide Presupuesto Gratis
          </a>
          <a href={`tel:${SITE.phone}`} class="inline-block text-center px-8 py-4 font-bold text-sm tracking-widest uppercase text-white border-2 border-white/30 hover:border-white transition-colors">
            ☎ {SITE.phoneDisplay}
          </a>
        </div>
      </div>
    </div>

    <!-- Stats bar -->
    <div class="relative border-t border-white/10 bg-white/5">
      <div class="max-w-7xl mx-auto px-4 py-8 grid grid-cols-2 lg:grid-cols-4 gap-6 text-center">
        {[
          { n: SITE.stats.projects, label: 'Obras realizadas' },
          { n: SITE.stats.years, label: 'Años en el sector' },
          { n: SITE.stats.cities, label: 'Municipios del Corredor' },
          { n: '100%', label: 'Precio cerrado garantizado' },
        ].map(s => (
          <div>
            <div class="text-4xl font-black text-[#A85535] mb-1">{s.n}</div>
            <div class="text-sm text-gray-400">{s.label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SERVICIOS -->
  <section id="servicios" class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Nuestros servicios</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">¿Qué quieres reformar?</h2>
        <div class="w-12 h-1 bg-[#A85535] mb-5"></div>
        <p class="text-lg text-gray-500 max-w-xl">Reformas integrales y parciales en Alcalá de Henares y toda la zona del Corredor del Henares.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {SERVICES.map(s => (
          <a href={`/servicios/${s.slug}/`}
            class="group block p-8 bg-gray-50 border-b-4 border-transparent hover:border-[#A85535] hover:shadow-xl hover:-translate-y-1 transition-all duration-200">
            <div class="text-4xl mb-5">{s.icon}</div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">{s.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed mb-4">{s.desc}</p>
            <p class="text-xs font-bold text-gray-400 mb-4">Desde <span class="text-[#A85535] text-base font-black">{s.priceFrom}€</span></p>
            <span class="text-sm font-bold uppercase tracking-wider text-[#A85535] flex items-center gap-2 group-hover:gap-3 transition-all">
              Ver más →
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- POR QUÉ NOSOTROS -->
  <section id="nosotros" class="py-24 lg:py-32 bg-[#F9F7F4]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Por qué elegir Trazzo360</p>
          <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-6" style="letter-spacing:-0.02em">
            Reformas con precio cerrado<br/>y plazo garantizado.
          </h2>
          <div class="w-12 h-1 bg-[#A85535] mb-8"></div>
          <div class="space-y-6">
            {[
              { title: 'Precio cerrado por contrato', desc: 'El presupuesto que firmas es el que pagas. Sin extras ni sorpresas al final de la obra.' },
              { title: 'Plazo garantizado', desc: 'La fecha de entrega se incluye en el contrato. Si nos retrasamos por causas propias, compensamos.' },
              { title: 'Equipo propio', desc: 'No subcontratamos. Nuestros operarios son empleados de Trazzo360, lo que garantiza calidad y control.' },
              { title: 'Pago por fases', desc: 'Pagas según avanza la obra, no todo por adelantado. Total transparencia en cada etapa.' },
            ].map(item => (
              <div class="flex gap-4">
                <div class="w-6 h-6 rounded-full bg-[#A85535] flex items-center justify-center flex-shrink-0 mt-0.5">
                  <svg class="w-3 h-3 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                </div>
                <div>
                  <h3 class="font-bold text-gray-900 mb-1">{item.title}</h3>
                  <p class="text-sm text-gray-500 leading-relaxed">{item.desc}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        <div class="bg-[#111827] p-10 text-white">
          <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-6">Nuestros números</p>
          <div class="grid grid-cols-2 gap-8">
            {[
              { n: SITE.stats.projects, label: 'Obras completadas' },
              { n: SITE.stats.years, label: 'Años de experiencia' },
              { n: SITE.stats.cities, label: 'Municipios cubiertos' },
              { n: '100%', label: 'Precio cerrado siempre' },
            ].map(s => (
              <div>
                <div class="text-5xl font-black text-[#A85535] mb-2">{s.n}</div>
                <div class="text-sm text-gray-400">{s.label}</div>
              </div>
            ))}
          </div>
          <a href="/contacto/" class="inline-block mt-10 px-7 py-3.5 text-sm font-bold uppercase tracking-widest text-white hover:opacity-90 transition-opacity" style="background:#A85535">
            Pedir presupuesto gratis
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- PROCESO -->
  <section id="proceso" class="py-24 lg:py-32 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center mb-16">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Cómo trabajamos</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">Tu reforma, paso a paso.</h2>
        <div class="w-12 h-1 bg-[#A85535] mx-auto"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
        {[
          { n: '01', title: 'Visita gratuita', desc: 'Visitamos tu vivienda, tomamos medidas y evaluamos el estado de todas las instalaciones.' },
          { n: '02', title: 'Presupuesto cerrado', desc: 'En 24–48h recibes un presupuesto detallado con precio y plazo fijos. Sin letra pequeña.' },
          { n: '03', title: 'Ejecución', desc: 'Nuestro equipo propio ejecuta la obra con seguimiento diario y comunicación constante.' },
          { n: '04', title: 'Entrega llave en mano', desc: 'Entregamos la obra limpia y revisada. Garantía de 2 años sobre la ejecución.' },
        ].map(step => (
          <div class="text-center">
            <div class="text-6xl font-black text-[#A85535]/20 mb-4">{step.n}</div>
            <h3 class="text-lg font-bold text-gray-900 mb-3">{step.title}</h3>
            <p class="text-sm text-gray-500 leading-relaxed">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ZONAS -->
  <section id="zonas" class="py-24 lg:py-32 bg-[#111827]">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid lg:grid-cols-2 gap-16 items-center">
        <div>
          <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Zona de actuación</p>
          <h2 class="text-4xl lg:text-5xl font-black text-white mb-4" style="letter-spacing:-0.02em">
            Reformamos en<br/>todo el Corredor.
          </h2>
          <div class="w-12 h-1 bg-[#A85535] mb-6"></div>
          <p class="text-lg text-gray-300 leading-relaxed mb-8">
            Cubrimos {SITE.stats.cities} municipios entre Madrid y Guadalajara con equipo propio y tiempos de respuesta rápidos.
          </p>
          <a href="/contacto/" class="inline-block px-8 py-4 text-sm font-bold uppercase tracking-widest text-white hover:opacity-90 transition-opacity" style="background:#A85535">
            Reformas en mi zona
          </a>
        </div>
        <div>
          <div class="flex flex-wrap gap-2">
            {ZONES.map(z => (
              <a href={`/zonas/${z.slug}/`}
                class={`inline-block px-4 py-2.5 text-sm font-medium transition-opacity hover:opacity-80 ${z.primary ? 'text-white' : 'text-gray-300 border border-white/20'}`}
                style={z.primary ? 'background:#A85535' : 'background:rgba(255,255,255,0.06)'}>
                {z.name}
              </a>
            ))}
          </div>
          <p class="mt-6 text-sm text-gray-500">¿Tu municipio no aparece? Consúltanos — cubrimos zonas adyacentes.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-24 lg:py-32 bg-white">
    <div class="max-w-4xl mx-auto px-4">
      <div class="text-center mb-14">
        <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Preguntas frecuentes</p>
        <h2 class="text-4xl lg:text-5xl font-black text-gray-900 mb-4" style="letter-spacing:-0.02em">Todo lo que necesitas<br/>saber antes de reformar.</h2>
        <div class="w-12 h-1 bg-[#A85535] mx-auto"></div>
      </div>
      <div class="divide-y divide-gray-100">
        {faqs.map((faq, i) => (
          <details class="group py-5">
            <summary class="flex justify-between items-start gap-4 cursor-pointer list-none font-semibold text-gray-900">
              {faq.q}
              <span class="text-[#A85535] text-2xl leading-none flex-shrink-0 group-open:rotate-45 transition-transform">+</span>
            </summary>
            <p class="mt-4 text-gray-500 leading-relaxed text-sm">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA FINAL -->
  <section class="py-20 bg-[#A85535]">
    <div class="max-w-4xl mx-auto px-4 text-center">
      <h2 class="text-3xl lg:text-5xl font-black text-white mb-4" style="letter-spacing:-0.02em">¿Listo para reformar?</h2>
      <p class="text-white/80 text-lg mb-8">Presupuesto gratuito en 24h. Precio cerrado. Sin sorpresas.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href="/contacto/" class="inline-block px-10 py-4 font-bold text-sm uppercase tracking-widest bg-white text-[#A85535] hover:bg-gray-100 transition-colors">
          Pide Presupuesto Gratis
        </a>
        <a href={`tel:${SITE.phone}`} class="inline-block px-10 py-4 font-bold text-sm uppercase tracking-widest text-white border-2 border-white/50 hover:border-white transition-colors">
          ☎ {SITE.phoneDisplay}
        </a>
      </div>
    </div>
  </section>

</Layout>
