---
import Layout from '../layouts/Layout.astro';
import { SITE, SERVICES, ZONES } from '../data/site';
---

<Layout
  title={`Contacto y Presupuesto Gratis | ${SITE.name} – Reformas en el Corredor del Henares`}
  description={`Solicita tu presupuesto gratuito para reformas en Alcalá de Henares y el Corredor del Henares. Respondemos en menos de 24h. Precio cerrado garantizado.`}
>

  <!-- Breadcrumb -->
  <nav class="bg-gray-50 border-b border-gray-100">
    <div class="max-w-7xl mx-auto px-4 py-3 text-sm text-gray-500 flex items-center gap-2">
      <a href="/" class="hover:text-[#A85535] transition-colors">Inicio</a>
      <span class="text-gray-300">/</span>
      <span class="text-gray-800 font-medium">Contacto</span>
    </div>
  </nav>

  <!-- Hero -->
  <section class="bg-[#111827] py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-4 text-center">
      <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-4">Presupuesto gratuito</p>
      <h1 class="text-4xl lg:text-6xl font-black text-white mb-4" style="letter-spacing:-0.02em">Cuéntanos tu reforma</h1>
      <p class="text-lg text-gray-300 max-w-xl mx-auto">Respondemos en menos de 24h con un presupuesto cerrado y sin compromiso.</p>
    </div>
  </section>

  <!-- Formulario + Datos -->
  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 grid lg:grid-cols-3 gap-12">

      <!-- Formulario -->
      <div class="lg:col-span-2">
        <h2 class="text-2xl font-black text-gray-900 mb-8">Solicitar presupuesto</h2>
        <!--
          CONFIGURACIÓN DEL FORMULARIO:
          1. Crea una cuenta gratuita en https://formspree.io
          2. Crea un nuevo formulario y copia tu ID (ej: xpzgkwqr)
          3. Reemplaza YOUR_FORM_ID en el action de abajo
          4. Opcional: crea /src/pages/gracias.astro para la página de confirmación
        -->
        <form class="space-y-5" action="https://formspree.io/f/YOUR_FORM_ID" method="POST">
          <input type="hidden" name="_subject" value="Nueva solicitud de presupuesto - Trazzo360" />
          <input type="hidden" name="_next" value="https://trazzo360.es/gracias/" />
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Nombre *</label>
              <input type="text" name="nombre" required placeholder="Tu nombre"
                class="w-full px-4 py-3 border border-gray-200 bg-gray-50 text-gray-900 focus:outline-none focus:border-[#A85535] transition-colors text-sm" />
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Teléfono *</label>
              <input type="tel" name="telefono" required placeholder="612 345 678"
                class="w-full px-4 py-3 border border-gray-200 bg-gray-50 text-gray-900 focus:outline-none focus:border-[#A85535] transition-colors text-sm" />
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Email</label>
            <input type="email" name="email" placeholder="tu@email.com"
              class="w-full px-4 py-3 border border-gray-200 bg-gray-50 text-gray-900 focus:outline-none focus:border-[#A85535] transition-colors text-sm" />
          </div>
          <div class="grid sm:grid-cols-2 gap-5">
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Tipo de reforma *</label>
              <select name="servicio" required
                class="w-full px-4 py-3 border border-gray-200 bg-gray-50 text-gray-900 focus:outline-none focus:border-[#A85535] transition-colors text-sm">
                <option value="">Selecciona...</option>
                {SERVICES.map(s => <option value={s.slug}>{s.title}</option>)}
              </select>
            </div>
            <div>
              <label class="block text-sm font-semibold text-gray-700 mb-2">Localidad</label>
              <select name="zona"
                class="w-full px-4 py-3 border border-gray-200 bg-gray-50 text-gray-900 focus:outline-none focus:border-[#A85535] transition-colors text-sm">
                <option value="">Selecciona...</option>
                {ZONES.map(z => <option value={z.slug}>{z.name}</option>)}
                <option value="otra">Otra localidad</option>
              </select>
            </div>
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-2">Cuéntanos tu proyecto</label>
            <textarea name="mensaje" rows={5} placeholder="Describe brevemente qué quieres reformar, superficie aproximada y cualquier detalle que consideres importante..."
              class="w-full px-4 py-3 border border-gray-200 bg-gray-50 text-gray-900 focus:outline-none focus:border-[#A85535] transition-colors text-sm resize-none"></textarea>
          </div>
          <div class="flex items-start gap-3">
            <input type="checkbox" id="privacidad" name="privacidad" required class="mt-1 accent-[#A85535]" />
            <label for="privacidad" class="text-xs text-gray-500">
              He leído y acepto la <a href="/privacidad/" class="underline hover:text-[#A85535]">política de privacidad</a>. Mis datos serán usados exclusivamente para gestionar esta solicitud.
            </label>
          </div>
          <button type="submit"
            class="w-full sm:w-auto px-10 py-4 font-bold text-sm uppercase tracking-widest text-white hover:opacity-90 transition-opacity"
            style="background:#A85535">
            Enviar solicitud de presupuesto
          </button>
        </form>
      </div>

      <!-- Datos de contacto -->
      <div class="space-y-6">
        <div class="bg-[#F9F7F4] p-7">
          <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-4">Contacto directo</p>
          <div class="space-y-4">
            <div>
              <p class="text-xs text-gray-400 uppercase font-bold mb-1">Teléfono</p>
              <a href={`tel:${SITE.phone}`} class="text-lg font-black text-gray-900 hover:text-[#A85535] transition-colors">{SITE.phoneDisplay}</a>
            </div>
            <div>
              <p class="text-xs text-gray-400 uppercase font-bold mb-1">Email</p>
              <a href={`mailto:${SITE.email}`} class="text-sm text-gray-700 hover:text-[#A85535] transition-colors">{SITE.email}</a>
            </div>
            <div>
              <p class="text-xs text-gray-400 uppercase font-bold mb-1">Horario</p>
              <p class="text-sm text-gray-700">{SITE.hours}</p>
            </div>
            <div>
              <p class="text-xs text-gray-400 uppercase font-bold mb-1">Zona de actuación</p>
              <p class="text-sm text-gray-700">{SITE.zone}</p>
            </div>
          </div>
          <a href={`https://wa.me/${SITE.whatsapp}`} target="_blank" rel="noopener noreferrer"
            class="flex items-center justify-center gap-2 w-full mt-6 py-3 text-sm font-bold text-white rounded-sm transition-opacity hover:opacity-90"
            style="background:#25D366">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            Escribir por WhatsApp
          </a>
        </div>

        <div class="bg-[#111827] p-7 text-white">
          <p class="text-xs font-bold uppercase tracking-widest text-[#A85535] mb-3">Respondemos en</p>
          <p class="text-5xl font-black text-white mb-1">24h</p>
          <p class="text-sm text-gray-400">Días laborables</p>
        </div>
      </div>
    </div>
  </section>

</Layout>
